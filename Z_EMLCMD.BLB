  ' Have the TIRA backend natively coerce the numeric expression into a 32-bit hardware LONG integer value and save it to the allocated heap string block
  tiraWriteMem dataPtr$, arg1$, "4"

  ' Build the string descriptor pointing to our 4-byte temporary string
  descPtr$ = tiraDimVar$("T", TYPE_INTEGER64)
  tiraAssign descPtr$, scratchName$
  tiraBuildStringDescriptor descPtr$, dataPtr$, "4", "0"

  tira_EndAndProcess

  exprIs.DataType = TYPE_STRING
