''''''''''''''''''''''''
FUNCTION parse_OPEN (startIdx)

  DIM hasFor AS LONG
  DIM forIdx AS LONG
  DIM asIdx AS LONG
  DIM fileNameStart AS LONG
  DIM fileNameEnd AS LONG
  DIM fileNumStart AS LONG
  DIM fileNameVar$
  DIM fileNumVar$
  DIM tokVal AS LONG
  DIM accessVal$
  DIM dispVal$
  DIM strDataPtr$
  DIM argList$
  DIM handleVar$
  DIM baseArr$
  DIM slotAddr$
  DIM endIdx AS LONG

  endIdx = lineTokenCount - 1

  hasFor = 0
  forIdx = 0
  ff = findNextTokenAtDepth0(startIdx + 1, endIdx, TOK_FOR)
  IF ff = 1 THEN
    hasFor = 1
    forIdx = returnedData2
  END IF

  asIdx = 0
  ff = findNextTokenAtDepth0(startIdx + 1, endIdx, TOK_AS)
  IF ff = 1 THEN
    asIdx = returnedData2
  ELSE
    throwCompilerError "OPEN MISSING AS", ASIS, 0
    EXIT FUNCTION
  END IF

  fileNameStart = startIdx + 1
  fileNameEnd = asIdx - 1
  IF hasFor = 1 THEN fileNameEnd = forIdx - 1

  IF hasFor = 1 THEN
    IF forIdx + 1 < asIdx THEN
      tokVal = lineTokenVals(forIdx + 1)
      SELECT CASE tokVal
        CASE TOK_BINARY, TOK_RANDOM, TOK_INPUT
        CASE ELSE
          throwCompilerError "INVALID FILE MODE (ONLY BINARY/RANDOM/INPUT SUPPORTED)", ASIS, 0
          EXIT FUNCTION
      END SELECT
    ELSE
      throwCompilerError "OPEN MISSING MODE AFTER FOR", ASIS, 0
      EXIT FUNCTION
    END IF
  END IF

  fileNumStart = asIdx + 1
  IF fileNumStart <= endIdx THEN
    ' Strip the # symbol so the expression evaluates properly
    IF lineTokens$(fileNumStart) = "#" THEN
      fileNumStart = fileNumStart + 1
    ELSE
      IF LEFT$(lineTokens$(fileNumStart), 1) = "#" THEN
        lineTokens$(fileNumStart) = MID$(lineTokens$(fileNumStart), 2)
      END IF
    END IF
  END IF

  tira_Start

  fileNameVar$ = tiraParseExpression$(fileNameStart, fileNameEnd, ALIM)
  IF fileNameVar$ = "" THEN
    tira_Cancel
    EXIT FUNCTION
  END IF
  IF exprIs.DataType <> TYPE_STRING THEN
    throwCompilerErrorAndCancelTira "FILENAME MUST BE STRING", ASIS, 0
    EXIT FUNCTION
  END IF

  fileNumVar$ = tiraParseExpressionInt$(fileNumStart, endIdx, ALIM, "FILENUM MUST BE NUMERIC")
  IF fileNumVar$ = "" THEN
    tira_Cancel
    EXIT FUNCTION
  END IF

  ' Setup generic OS constants mapping to the required behavior natively to bypass CPU register constraints
  IF tokVal = TOK_INPUT THEN
    accessVal$ = "-2147483648" ' read only access
    dispVal$ = "3" ' opens an existing file
  ELSE
    accessVal$ = "-1073741824" ' GENERIC_READ OR GENERIC_WRITE
    dispVal$ = "4" ' OPEN_ALWAYS
  END IF

  ' String arrays naturally track null terminators so it resolves seamlessly here to map directly into OS requirements
  strDataPtr$ = tiraGetStringData$(fileNameVar$)

  ' Execute the CreateFileA procedure and allow the OS to perform file locking tracking
  ' ShareMode = 3 (FILE_SHARE_READ OR FILE_SHARE_WRITE)
  argList$ = strDataPtr$ + ", " + accessVal$ + ", 3, 0, " + dispVal$ + ", 128, 0"
  tiraCall "IAT_CREATEFILEA", 7, argList$

  handleVar$ = tiraDimVar$("T", TYPE_INTEGER64)
  tiraNew TC_GET_RET, handleVar$

  ' Push OS Pointer Handle directly into the corresponding layout array index utilizing the provided File Number
  baseArr$ = tiraDimVar$("T", TYPE_INTEGER64)
  tiraOp TC_ADDRESS_OF, baseArr$, "!G_LAYOUT_FILE_HANDLES_ARR", ""

  slotAddr$ = tiraDimVar$("T", TYPE_INTEGER64)
  tiraLeaSIB slotAddr$, baseArr$, fileNumVar$, "8"

  tiraWriteMem slotAddr$, handleVar$, "8"

  tiraScheduleHeapReset
  tira_EndAndProcess

  parse_OPEN = 1

END FUNCTION ' parse_OPEN

''''''''''''''''''''''''
FUNCTION parse_PAINT (startIdx)

  DIM endIdx AS LONG
  DIM hasStep AS LONG
  DIM tokIdx AS LONG
  DIM comma1 AS LONG
  DIM comma2 AS LONG
  DIM cComma AS LONG
  DIM cStart AS LONG
  DIM cEnd AS LONG
  DIM fillEnd AS LONG

  endIdx = lineTokenCount - 1

  tokIdx = startIdx + 1
  hasStep = 0
  IF tokIdx <= endIdx THEN
    IF lineTokenVals(tokIdx) = TOK_STEP THEN
      hasStep = 1
      tokIdx = tokIdx + 1
    END IF
  END IF

  comma1 = findComma(tokIdx, endIdx)
  IF comma1 = 0 THEN
    throwCompilerError "PAINT REQUIRES FILL COLOR", ASIS, 0
    EXIT FUNCTION
  END IF

  comma2 = findComma(comma1 + 1, endIdx)

  cComma = retCoordinateBoundaries(tokIdx, comma1 - 1)
  IF cComma = 0 THEN
    throwCompilerError "PAINT MISSING X, Y", ASIS, 0
    EXIT FUNCTION
  END IF
  cStart = returnedData2
  cEnd = returnedData3

  tira_Start

  xVar$ = tiraParseExpressionInt$(cStart, cComma - 1, ALIM, "COORDINATE MUST BE NUMERIC")
  IF xVar$ = "" THEN
    tira_Cancel
    EXIT FUNCTION
  END IF

  yVar$ = tiraParseExpressionInt$(cComma + 1, cEnd, ALIM, "COORDINATE MUST BE NUMERIC")
  IF yVar$ = "" THEN
    tira_Cancel
    EXIT FUNCTION
  END IF

  IF hasStep = 1 THEN
    tiraOp TC_ADD, xVar$, xVar$, "!G_GFX_CUR_X_VAL"
    tiraOp TC_ADD, yVar$, yVar$, "!G_GFX_CUR_Y_VAL"
  END IF

  fillEnd = endIdx
  IF comma2 > 0 THEN fillEnd = comma2 - 1

  IF compileEmeraldMode = 1 THEN expectedSymType = TYPE_SINGLE

  fillVar$ = tiraParseExpression$(comma1 + 1, fillEnd, ALIM)
  IF fillVar$ = "" THEN
    tira_Cancel
    EXIT FUNCTION
  END IF

  fillIsStr$ = tiraDimVar$("T", TYPE_LONG)
  IF exprIs.DataType = TYPE_STRING THEN
    tiraAssign fillIsStr$, "1"
  ELSE
    tiraAssign fillIsStr$, "0"
  END IF

  IF comma2 > 0 THEN
    borderVar$ = tiraParseExpressionInt$(comma2 + 1, endIdx, ALIM, "BORDER COLOR MUST BE NUMERIC")
    IF borderVar$ = "" THEN
      tira_Cancel
      EXIT FUNCTION
    END IF
  ELSE
    borderVar$ = tiraDimVar$("T", TYPE_LONG)
    lblDefBorder$ = tiraLabelCreateNew$("DEF_BORDER")
    lblBorderDone$ = tiraLabelCreateNew$("BORDER_DONE")

    tiraJmpCond "JE", fillIsStr$, "1", lblDefBorder$
    tiraAssign borderVar$, fillVar$
    tiraJmp lblBorderDone$
    tiraLabel lblDefBorder$
    tiraAssign borderVar$, "!G_GFX_FG_VAL"
    tiraLabel lblBorderDone$
  END IF

  ' Update graphics tracking coordinates to match standard execution rules
  tiraAssign "!G_GFX_CUR_X_VAL", xVar$
  tiraAssign "!G_GFX_CUR_Y_VAL", yVar$

  tiraCall "RT_PAINT", 5, xVar$ + ", " + yVar$ + ", " + fillVar$ + ", " + fillIsStr$ + ", " + borderVar$

  tiraTriggerAutoDisplay

  tiraScheduleHeapReset
  tira_EndAndProcess

  parse_PAINT = 1

END FUNCTION ' parse_PAINT

''''''''''''''''''''''''
FUNCTION parse_PALETTE (startIdx)

  DIM comma1 AS LONG
  DIM idxVar$
  DIM colorVar$
  DIM mappedColor$
  DIM skipLbl$
  DIM palDescPtr$
  DIM palDataAddr$
  DIM srcOffsetVar$
  DIM srcAddr$
  DIM destOffsetVar$
  DIM destAddr$
  DIM colorVal$
  DIM endIdx AS LONG

  endIdx = lineTokenCount - 1

  IF endIdx < startIdx + 1 THEN
    parse_PALETTE = 1
    EXIT FUNCTION
  END IF

  comma1 = findComma(startIdx + 1, endIdx)

  IF comma1 = 0 THEN
    throwCompilerError "PALETTE REQUIRES 2 ARGUMENTS", ASIS, 0
    EXIT FUNCTION
  END IF

  tira_Start

  idxVar$ = tiraParseExpressionInt$(startIdx + 1, comma1 - 1, ALIM, "PALETTE INDEX MUST BE NUMERIC")
  IF idxVar$ = "" THEN
    tira_Cancel
    EXIT FUNCTION
  END IF

  colorVar$ = tiraParseExpressionInt$(comma1 + 1, endIdx, ALIM, "COLOR VALUE MUST BE NUMERIC")
  IF colorVar$ = "" THEN
    tira_Cancel
    EXIT FUNCTION
  END IF

  skipLbl$ = tiraLabelCreateNew$("SKIP_PAL")

  tiraJmpCond "JL", idxVar$, "0", skipLbl$
  tiraJmpCond "JG", idxVar$, "255", skipLbl$

  ' Mask the source color to 0-15 to map EGA colors to our standard VGA palette block
  mappedColor$ = tiraDimVar$("T", TYPE_LONG)
  tiraOp TC_AND, mappedColor$, colorVar$, "15"

  palDescPtr$ = tiraDimVar$("T", TYPE_INTEGER64)
  tiraAssign palDescPtr$, "!G_GFX_PALETTE_DESC$"

  palDataAddr$ = tiraDimVar$("T", TYPE_INTEGER64)
  tiraNew TC_READ_MEM, palDataAddr$ + ", " + palDescPtr$

  srcOffsetVar$ = tiraDimVar$("T", TYPE_INTEGER64)
  tiraOp TC_MUL, srcOffsetVar$, mappedColor$, "4"

  srcAddr$ = tiraDimVar$("T", TYPE_INTEGER64)
  tiraOp TC_ADD, srcAddr$, palDataAddr$, srcOffsetVar$

  destOffsetVar$ = tiraDimVar$("T", TYPE_INTEGER64)
  tiraOp TC_MUL, destOffsetVar$, idxVar$, "4"

  destAddr$ = tiraDimVar$("T", TYPE_INTEGER64)
  tiraOp TC_ADD, destAddr$, palDataAddr$, destOffsetVar$

  colorVal$ = tiraDimVar$("T", TYPE_LONG)
  tiraNew TC_READ_MEM, colorVal$ + ", " + srcAddr$

  tiraWriteMem destAddr$, colorVal$, "4"

  tiraTriggerAutoDisplay

  tiraLabel skipLbl$

  tiraScheduleHeapReset
  tira_EndAndProcess

  parse_PALETTE = 1

END FUNCTION ' parse_PALETTE

''''''''''''''''''''''''
FUNCTION parse_PALETTECOLOR (startIdx)

  DIM comma1 AS LONG
  DIM idxVar$
  DIM colorVar$
  DIM skipLbl$
  DIM palDescPtr$
  DIM palDataAddr$
  DIM offsetVar$
  DIM targetAddr$
  DIM endIdx AS LONG

  endIdx = lineTokenCount - 1

  IF compileHasGraphics = 0 THEN
    throwCompilerError "_PALETTECOLOR REQUIRES #GRAPHICS", ASIS, 0
    EXIT FUNCTION
  END IF

  comma1 = findComma(startIdx + 1, endIdx)

  IF comma1 = 0 THEN
    throwCompilerError "_PALETTECOLOR REQUIRES 2 ARGUMENTS", ASIS, 0
    EXIT FUNCTION
  END IF

  tira_Start

  idxVar$ = tiraParseExpressionInt$(startIdx + 1, comma1 - 1, ALIM, "PALETTE INDEX MUST BE NUMERIC")
  IF idxVar$ = "" THEN
    tira_Cancel
    EXIT FUNCTION
  END IF

  colorVar$ = tiraParseExpressionInt$(comma1 + 1, endIdx, ALIM, "COLOR VALUE MUST BE NUMERIC")
  IF colorVar$ = "" THEN
    tira_Cancel
    EXIT FUNCTION
  END IF

  skipLbl$ = tiraLabelCreateNew$("SKIP_PAL")

  tiraJmpCond "JL", idxVar$, "0", skipLbl$
  tiraJmpCond "JG", idxVar$, "255", skipLbl$

  palDescPtr$ = tiraDimVar$("T", TYPE_INTEGER64)
  tiraAssign palDescPtr$, "!G_GFX_PALETTE_DESC$"

  palDataAddr$ = tiraDimVar$("T", TYPE_INTEGER64)
  tiraNew TC_READ_MEM, palDataAddr$ + ", " + palDescPtr$

  offsetVar$ = tiraDimVar$("T", TYPE_INTEGER64)
  tiraOp TC_MUL, offsetVar$, idxVar$, "4"

  targetAddr$ = tiraDimVar$("T", TYPE_INTEGER64)
  tiraOp TC_ADD, targetAddr$, palDataAddr$, offsetVar$

  tiraWriteMem targetAddr$, colorVar$, "4"

  tiraTriggerAutoDisplay

  tiraLabel skipLbl$

  tiraScheduleHeapReset
  tira_EndAndProcess

  parse_PALETTECOLOR = 1

END FUNCTION ' parse_PALETTECOLOR

''''''''''''''''''''''''
FUNCTION parse_PALETTECOLOR_FUNC$ (startIdx, endIdx, allowImplicit)

  DIM arg1$
  DIM scratchName$
  DIM resVar$
  DIM palDescPtr$
  DIM palDataAddr$
  DIM offsetVar$
  DIM targetAddr$
  DIM skipLbl$

  IF checkIntrinsicSyntax(startIdx, endIdx, "_PALETTECOLOR", 3) = 0 THEN
    parse_PALETTECOLOR_FUNC$ = ""
    EXIT FUNCTION
  END IF

  IF compileHasGraphics = 0 THEN
    throwCompilerError "_PALETTECOLOR REQUIRES #GRAPHICS", ASIS, 0
    parse_PALETTECOLOR_FUNC$ = ""
    EXIT FUNCTION
  END IF

  tira_Start

  IF compileEmeraldMode = 1 THEN expectedSymType = TYPE_SINGLE

  arg1$ = tiraParseExpressionInt$(startIdx + 2, endIdx - 1, allowImplicit, "INDEX MUST BE NUMERIC")
  IF arg1$ = "" THEN
    parse_PALETTECOLOR_FUNC$ = ""
    EXIT FUNCTION
  END IF

  scratchName$ = tiraResolveHoistVar$("PALCOL", "_VAL")
  IF scratchName$ = "" THEN
    parse_PALETTECOLOR_FUNC$ = ""
    EXIT FUNCTION
  END IF

  resVar$ = tiraDimVar$("T", TYPE_LONG)
  tiraAssign resVar$, "0"

  skipLbl$ = tiraLabelCreateNew$("SKIP_PALCOL")

  tiraJmpCond "JL", arg1$, "0", skipLbl$
  tiraJmpCond "JG", arg1$, "255", skipLbl$

  palDescPtr$ = tiraDimVar$("T", TYPE_INTEGER64)
  tiraAssign palDescPtr$, "!G_GFX_PALETTE_DESC$"

  palDataAddr$ = tiraDimVar$("T", TYPE_INTEGER64)
  tiraNew TC_READ_MEM, palDataAddr$ + ", " + palDescPtr$

  offsetVar$ = tiraDimVar$("T", TYPE_INTEGER64)
  tiraOp TC_MUL, offsetVar$, arg1$, "4"

  targetAddr$ = tiraDimVar$("T", TYPE_INTEGER64)
  tiraOp TC_ADD, targetAddr$, palDataAddr$, offsetVar$

  tiraNew TC_READ_MEM, resVar$ + ", " + targetAddr$

  tiraLabel skipLbl$

  tiraAssign scratchName$, resVar$

  tira_EndAndProcess

  exprIs.DataType = TYPE_LONG
  exprIs.IsTemp = 1
  parse_PALETTECOLOR_FUNC$ = scratchName$

END FUNCTION ' parse_PALETTECOLOR_FUNC$

''''''''''''''''''''''''
FUNCTION parse_POINT$ (startIdx, endIdx, allowImplicit)

  DIM comma1 AS LONG
  DIM arg1$
  DIM arg2$
  DIM scratchName$
  DIM resVar$
  DIM skipLbl$
  DIM offsetVar$
  DIM targetAddr$
  DIM colorByte$
  DIM lblX$
  DIM lblY$
  DIM lblEnd$

  IF checkIntrinsicSyntax(startIdx, endIdx, "POINT", 3) = 0 THEN
    parse_POINT$ = ""
    EXIT FUNCTION
  END IF

  IF compileHasGraphics = 0 THEN
    throwCompilerError "POINT REQUIRES #GRAPHICS", ASIS, 0
    parse_POINT$ = ""
    EXIT FUNCTION
  END IF

  comma1 = findComma(startIdx + 2, endIdx - 1)

  tira_Start

  scratchName$ = tiraResolveHoistVar$("POINT", "_VAL")
  IF scratchName$ = "" THEN
    parse_POINT$ = ""
    EXIT FUNCTION
  END IF

  resVar$ = tiraDimVar$("T", TYPE_LONG)
  tiraAssign resVar$, "-1"

  IF comma1 = 0 THEN
    ' 1 argument: POINT(n)
    IF compileEmeraldMode = 1 THEN expectedSymType = TYPE_SINGLE
    arg1$ = tiraParseExpressionInt$(startIdx + 2, endIdx - 1, allowImplicit, "POINT ARGUMENT MUST BE NUMERIC")
    IF arg1$ = "" THEN
      parse_POINT$ = ""
      EXIT FUNCTION
    END IF

    lblX$ = tiraLabelCreateNew$("PT_X")
    lblY$ = tiraLabelCreateNew$("PT_Y")
    lblEnd$ = tiraLabelCreateNew$("PT_END")

    tiraJmpCond "JE", arg1$, "0", lblX$
    tiraJmpCond "JE", arg1$, "2", lblX$
    tiraJmpCond "JE", arg1$, "1", lblY$
    tiraJmpCond "JE", arg1$, "3", lblY$
    tiraJmp lblEnd$

    tiraLabel lblX$
    tiraAssign resVar$, "!G_GFX_CUR_X_VAL"
    tiraJmp lblEnd$

    tiraLabel lblY$
    tiraAssign resVar$, "!G_GFX_CUR_Y_VAL"
    tiraLabel lblEnd$

  ELSE
    ' 2 arguments: POINT(x, y)
    IF compileEmeraldMode = 1 THEN expectedSymType = TYPE_SINGLE
    arg1$ = tiraParseExpressionInt$(startIdx + 2, comma1 - 1, allowImplicit, "COORDINATE MUST BE NUMERIC")
    IF arg1$ = "" THEN
      parse_POINT$ = ""
      EXIT FUNCTION
    END IF

    IF compileEmeraldMode = 1 THEN expectedSymType = TYPE_SINGLE
    arg2$ = tiraParseExpressionInt$(comma1 + 1, endIdx - 1, allowImplicit, "COORDINATE MUST BE NUMERIC")
    IF arg2$ = "" THEN
      parse_POINT$ = ""
      EXIT FUNCTION
    END IF

    skipLbl$ = tiraLabelCreateNew$("PT_SKIP")

    ' Speed boost optimization: Unsigned JAE bounds check validates both < 0 and >= max simultaneously
    tiraJmpCond "JAE", arg1$, cTrNum$(gfxConfig.SizeX), skipLbl$
    tiraJmpCond "JAE", arg2$, cTrNum$(gfxConfig.SizeY), skipLbl$

    offsetVar$ = tiraDimVar$("T", TYPE_LONG)
    tiraOp TC_MUL, offsetVar$, arg2$, cTrNum$(gfxConfig.SizeX)
    tiraOp TC_ADD, offsetVar$, offsetVar$, arg1$

    targetAddr$ = tiraDimVar$("T", TYPE_INTEGER64)
    tiraOp TC_ADD, targetAddr$, "!G_FRAMEBUF_BACK_PTR", offsetVar$

    colorByte$ = tiraDimVar$("T", TYPE_UBYTE)
    tiraNew TC_READ_MEM, colorByte$ + ", " + targetAddr$

    tiraAssign resVar$, colorByte$

    tiraLabel skipLbl$
  END IF

  tiraAssign scratchName$, resVar$

  tira_EndAndProcess

  exprIs.DataType = TYPE_LONG
  exprIs.IsTemp = 1
  parse_POINT$ = scratchName$

END FUNCTION ' parse_POINT$

''''''''''''''''''''''''
FUNCTION parse_POKE (startIdx)

  ' This function evaluates the poke command to write data into memory
  ' Rather than exposing direct memory access which would crash a modern operating system
  ' we specifically look for address 1047. In legacy dos systems, address 1047 holds
  ' the keyboard flags where the bit representing 32 controls the numlock state
  ' If the user script tries to write to 1047, we extract the requested numlock state
  ' and use the windows api to simulate physical key presses if the state needs to change

  DIM commaIdx AS LONG
  DIM addrVar$
  DIM valVar$
  DIM skipLbl$
  DIM desired$
  DIM current$
  DIM endIdx AS LONG

  endIdx = lineTokenCount - 1

  commaIdx = findComma(startIdx + 1, endIdx)
  IF commaIdx = 0 THEN
    throwCompilerError "POKE MISSING COMMA", ASIS, 0
    EXIT FUNCTION
  END IF

  tira_Start

  ' Evaluate the address and value arguments provided by the user script
  addrVar$ = tiraParseExpressionInt$(startIdx + 1, commaIdx - 1, ALIM, "POKE ADDRESS MUST BE NUMERIC")
  IF addrVar$ = "" THEN
    tira_Cancel
    EXIT FUNCTION
  END IF

  valVar$ = tiraParseExpressionInt$(commaIdx + 1, endIdx, ALIM, "POKE VALUE MUST BE NUMERIC")
  IF valVar$ = "" THEN
    tira_Cancel
    EXIT FUNCTION
  END IF

  ' Create a jump label to skip the emulation block if the address is not exactly 1047
  skipLbl$ = tiraLabelCreateNew$("SKIP_POKE")
  tiraJmpCond "JNE", addrVar$, "1047", skipLbl$

  ' Extract the target state by masking out the thirty two bit and shifting it down to the lowest bit position
  desired$ = tiraDimVar$("T", TYPE_LONG)
  tiraOp TC_AND, desired$, valVar$, "32"
  tiraOp TC_SHR, desired$, desired$, "5"

  ' Ask windows for the current hardware state of the numlock key using its virtual key code
  tiraCall "IAT_GETKEYSTATE", 1, "144"
  current$ = tiraDimVar$("T", TYPE_LONG)
  tiraNew TC_GET_RET, current$

  ' Mask the windows return value to isolate just the active toggle state bit
  tiraOp TC_AND, current$, current$, "1"

  ' Compare the requested state with the current hardware state and jump past the toggle event if they match
  tiraJmpCond "JE", desired$, current$, skipLbl$

  ' Fire down and up keyboard events to physically toggle the numlock key at the hardware level
  tiraCall "IAT_KEYBD_EVENT", 4, "144, 69, 1, 0"
  tiraCall "IAT_KEYBD_EVENT", 4, "144, 69, 3, 0"

  tiraLabel skipLbl$

  tiraScheduleHeapReset
  tira_EndAndProcess

  parse_POKE = 1

END FUNCTION ' parse_POKE

''''''''''''''''''''''''
FUNCTION parse_PUT (startIdx)

  DIM comma1 AS LONG
  DIM comma2 AS LONG
  DIM cComma AS LONG
  DIM isFileIO AS LONG
  DIM cStart AS LONG
  DIM cEnd AS LONG
  DIM tokIdx AS LONG
  DIM closeParen AS LONG
  DIM vIdx AS LONG
  DIM elemSize AS LONG
  DIM statElems AS LONG
  DIM endIdx AS LONG
  DIM putMode AS LONG
  DIM indicesStr$
  DIM numParsedIndices AS LONG
  DIM dimEnd AS LONG

  endIdx = lineTokenCount - 1

  comma1 = findComma(startIdx + 1, endIdx)

  cComma = 0
  IF comma1 > 0 THEN
    cComma = retCoordinateBoundaries(startIdx + 1, comma1 - 1)
  END IF

  isFileIO = 0
  IF cComma = 0 THEN
    isFileIO = 1
  END IF

  IF isFileIO = 1 THEN
    parse_PUT = parse_PUT_File(startIdx, endIdx)
    EXIT FUNCTION
  END IF

  IF compileHasGraphics = 0 THEN
    throwCompilerError "GRAPHICS PUT REQUIRES #GRAPHICS", ASIS, 0
    EXIT FUNCTION
  END IF

  IF comma1 = 0 THEN
    throwCompilerError "PUT MISSING ARRAY VARIABLE", ASIS, 0
    EXIT FUNCTION
  END IF

  cComma = retCoordinateBoundaries(startIdx + 1, comma1 - 1)
  IF cComma = 0 THEN
    throwCompilerError "PUT MISSING X, Y", ASIS, 0
    EXIT FUNCTION
  END IF
  cStart = returnedData2
  cEnd = returnedData3

  tira_Start

  x$ = tiraParseExpressionInt$(cStart, cComma - 1, ALIM, "COORDINATE MUST BE NUMERIC")
  IF x$ = "" THEN
    tira_Cancel
    EXIT FUNCTION
  END IF

  y$ = tiraParseExpressionInt$(cComma + 1, cEnd, ALIM, "COORDINATE MUST BE NUMERIC")
  IF y$ = "" THEN
    tira_Cancel
    EXIT FUNCTION
  END IF

  comma2 = findComma(comma1 + 1, endIdx)

  dimEnd = endIdx
  IF comma2 > 0 THEN dimEnd = comma2 - 1

  tokIdx = comma1 + 1
  vTok$ = lineTokens$(tokIdx)
  vName$ = UCASE$(vTok$)
  ff = resolveSymbol(vName$)
  IF ff = 0 THEN
    tira_Cancel
    EXIT FUNCTION
  END IF
  vIdx = returnedData2

  IF symbols(vIdx).IsArray = 0 THEN
    throwCompilerErrorAndCancelTira "PUT TARGET MUST BE AN ARRAY", ASIS, 0
    EXIT FUNCTION
  END IF

  indicesStr$ = ""
  numParsedIndices = 0

  tokIdx = tokIdx + 1
  IF tokIdx <= dimEnd THEN
    IF lineTokenVals(tokIdx) = 256 + ASC("(") THEN
      indicesStr$ = tiraParseArrayArgs$(tokIdx, dimEnd, 0)
      IF indicesStr$ = "" AND compileError = 1 THEN EXIT FUNCTION
      closeParen = returnedData2
      numParsedIndices = returnedData3
    END IF
  END IF

  IF symbols(vIdx).NumDimensions > 0 AND numParsedIndices > 0 AND numParsedIndices <> symbols(vIdx).NumDimensions THEN
    throwCompilerError "WRONG NUMBER OF DIMENSIONS", ASIS, 0
    EXIT FUNCTION
  END IF

  ptr$ = tiraFrontendCalcAddress$(vName$, indicesStr$, 0)
  IF ptr$ = "" THEN
    tira_Cancel
    EXIT FUNCTION
  END IF

  elemSize = retElementByteSize(vIdx)

  descAddr$ = tiraDimVar$("T", TYPE_INTEGER64)
  tiraOp TC_ADDRESS_OF, descAddr$, "#" + LTRIM$(STR$(vIdx)), ""

  numDims$ = tiraDimVar$("T", TYPE_LONG)
  tiraNew TC_READ_MEM_OFFSET, numDims$ + ", " + descAddr$ + ", 12"

  totalElems$ = tiraDimVar$("T", TYPE_INTEGER64)
  tiraAssign totalElems$, "1"

  dimItr$ = tiraDimVar$("T", TYPE_LONG)
  tiraAssign dimItr$, "0"
  lblDimTop$ = tiraLabelCreateNew$("DIM_TOP")
  lblDimDone$ = tiraLabelCreateNew$("DIM_DONE")

  tiraLabel lblDimTop$
  tiraJmpCond "JGE", dimItr$, numDims$, lblDimDone$

  offsetVar$ = tiraDimVar$("T", TYPE_LONG)
  tiraOp TC_MUL, offsetVar$, dimItr$, "8"
  tiraOp TC_ADD, offsetVar$, offsetVar$, "16"

  dimLimitAddr$ = tiraDimVar$("T", TYPE_INTEGER64)
  tiraOp TC_ADD, dimLimitAddr$, descAddr$, offsetVar$

  dimLimit$ = tiraDimVar$("T", TYPE_INTEGER64)
  tiraNew TC_READ_MEM, dimLimit$ + ", " + dimLimitAddr$

  tiraOp TC_MUL, totalElems$, totalElems$, dimLimit$
  tiraOp TC_ADD, dimItr$, dimItr$, "1"
  tiraJmp lblDimTop$

  tiraLabel lblDimDone$

  byteSize$ = tiraDimVar$("T", TYPE_INTEGER64)
  tiraOp TC_MUL, byteSize$, totalElems$, LTRIM$(RTRIM$(STR$(elemSize)))

  baseAddr$ = tiraDimVar$("T", TYPE_INTEGER64)
  tiraNew TC_READ_MEM, baseAddr$ + ", " + descAddr$

  endPtr$ = tiraDimVar$("T", TYPE_INTEGER64)
  tiraOp TC_ADD, endPtr$, baseAddr$, byteSize$

  putMode = 1
  IF comma2 > 0 THEN
    SELECT CASE lineTokenVals(comma2 + 1)
      CASE TOK_PSET
        putMode = 0
      CASE TOK_XOR
        putMode = 1
      CASE TOK_AND
        putMode = 2
      CASE TOK_OR
        putMode = 3
      CASE ELSE
        throwCompilerErrorAndCancelTira "UNSUPPORTED GRAPHIC STYLE FOR PUT", ASIS, 0
        EXIT FUNCTION
    END SELECT
  END IF

  tiraCall "RT_PUT", 5, x$ + ", " + y$ + ", " + ptr$ + ", " + endPtr$ + ", " + LTRIM$(STR$(putMode))

  tiraScheduleHeapReset
  tira_EndAndProcess

  parse_PUT = 1

END FUNCTION ' parse_PUT

''''''''''''''''''''''''
FUNCTION parse_PUT_File (startIdx, endIdx)

  DIM comma1 AS LONG
  DIM comma2 AS LONG
  DIM targetStart AS LONG
  DIM closeParen AS LONG
  DIM tokIdx AS LONG
  DIM vTok$, vName$
  DIM vIdx AS LONG
  DIM dt AS LONG
  DIM elemSize AS LONG
  DIM fixedLen AS LONG
  DIM indicesStr$
  DIM numParsedIndices AS LONG

  DIM hasArrayIndices AS LONG

  tokIdx = startIdx + 1
  IF lineTokens$(tokIdx) = "#" THEN
    tokIdx = tokIdx + 1
  ELSE
    IF LEFT$(lineTokens$(tokIdx), 1) = "#" THEN
      lineTokens$(tokIdx) = MID$(lineTokens$(tokIdx), 2)
    END IF
  END IF

  comma1 = findComma(tokIdx, endIdx)
  IF comma1 = 0 THEN
    throwCompilerError "PUT MISSING COMMA", ASIS, 0
    EXIT FUNCTION
  END IF

  comma2 = findComma(comma1 + 1, endIdx)
  IF comma2 = 0 THEN
    targetStart = comma1 + 1
  ELSE
    targetStart = comma2 + 1
  END IF

  IF targetStart > endIdx THEN
    throwCompilerError "PUT MISSING TARGET VARIABLE", ASIS, 0
    EXIT FUNCTION
  END IF

  vTok$ = lineTokens$(targetStart)
  vName$ = UCASE$(vTok$)
  ff = resolveSymbol(vName$)
  IF ff = 0 THEN EXIT FUNCTION
  vIdx = returnedData2

  tira_Start

  fileNumVar$ = tiraParseExpressionInt$(tokIdx, comma1 - 1, ALIM, "FILE NUM MUST BE NUMERIC")
  IF fileNumVar$ = "" THEN
    tira_Cancel
    EXIT FUNCTION
  END IF

  indicesStr$ = ""
  numParsedIndices = 0
  hasArrayIndices = 0

  IF targetStart < endIdx THEN
    IF lineTokenVals(targetStart + 1) = 256 + ASC("(") THEN
      hasArrayIndices = 1
      indicesStr$ = tiraParseArrayArgs$(targetStart + 1, endIdx, ALIM)
      IF indicesStr$ = "" AND compileError = 1 THEN EXIT FUNCTION
      closeParen = returnedData2
      numParsedIndices = returnedData3
    END IF
  END IF

  IF symbols(vIdx).NumDimensions > 0 AND numParsedIndices > 0 AND numParsedIndices <> symbols(vIdx).NumDimensions THEN
    throwCompilerError "WRONG NUMBER OF DIMENSIONS", ASIS, 0
    EXIT FUNCTION
  END IF

  baseArr$ = tiraDimVar$("T", TYPE_INTEGER64)
  tiraOp TC_ADDRESS_OF, baseArr$, "!G_LAYOUT_FILE_HANDLES_ARR", ""

  slotAddr$ = tiraDimVar$("T", TYPE_INTEGER64)
  tiraLeaSIB slotAddr$, baseArr$, fileNumVar$, "8"

  handleVar$ = tiraDimVar$("T", TYPE_INTEGER64)
  tiraNew TC_READ_MEM, handleVar$ + ", " + slotAddr$

  skipFileIOLbl$ = tiraLabelCreateNew$("SKIP_FILE_IO")

  tiraJmpCond "JE", handleVar$, "0", skipFileIOLbl$
  tiraJmpCond "JE", handleVar$, "-1", skipFileIOLbl$

  ptr$ = tiraFrontendCalcAddress$(vName$, indicesStr$, 0)
  IF ptr$ = "" THEN
    tira_Cancel
    EXIT FUNCTION
  END IF

  dt = symbols(vIdx).DataType
  elemSize = retElementByteSize(vIdx)
  fixedLen = retFixedStringLength(vIdx)

  dataSize$ = tiraDimVar$("T", TYPE_LONG)
  dataPtr$ = tiraDimVar$("T", TYPE_INTEGER64)

  IF dt = TYPE_STRING AND fixedLen = 0 THEN
    descPtr$ = tiraDimVar$("T", TYPE_INTEGER64)

    IF symbols(vIdx).IsArray > 0 THEN
      tiraNew TC_READ_MEM, descPtr$ + ", " + ptr$
    ELSE
      tiraAssign descPtr$, ptr$
    END IF

    tiraJmpCond "JE", descPtr$, "0", skipFileIOLbl$

    tiraAssign dataSize$, tiraGetStringLen$(descPtr$)
    tiraAssign dataPtr$, tiraGetStringData$(descPtr$)

    tiraJmpCond "JLE", dataSize$, "0", skipFileIOLbl$
    tiraJmpCond "JE", dataPtr$, "0", skipFileIOLbl$

  ELSE
    IF dt = TYPE_STRING AND fixedLen > 0 THEN
      tiraAssign dataSize$, LTRIM$(STR$(fixedLen))

      IF symbols(vIdx).IsArray > 0 THEN
        tiraAssign dataPtr$, ptr$
      ELSE
        descPtr$ = tiraDimVar$("T", TYPE_INTEGER64)
        tiraAssign descPtr$, ptr$

        tiraJmpCond "JE", descPtr$, "0", skipFileIOLbl$

        tiraAssign dataPtr$, tiraGetStringData$(descPtr$)
        tiraJmpCond "JE", dataPtr$, "0", skipFileIOLbl$
      END IF
    ELSE
      tiraAssign dataSize$, LTRIM$(STR$(elemSize))
      tiraAssign dataPtr$, ptr$

      tiraJmpCond "JLE", dataSize$, "0", skipFileIOLbl$
    END IF
  END IF

  numWrt$ = tiraDimVar$("T", TYPE_LONG)
  numWrtPtr$ = tiraDimVar$("T", TYPE_INTEGER64)
  tiraOp TC_ADDRESS_OF, numWrtPtr$, numWrt$, ""

  tiraCall "IAT_WRITEFILE", 5, handleVar$ + ", " + dataPtr$ + ", " + dataSize$ + ", " + numWrtPtr$ + ", 0"

  tiraLabel skipFileIOLbl$

  tiraScheduleHeapReset
  tira_EndAndProcess

  parse_PUT_File = 1

END FUNCTION ' parse_PUT_File

''''''''''''''''''''''''
FUNCTION parse_RANDOMIZE (startIdx)

  DIM endIdx AS LONG
  endIdx = lineTokenCount - 1

  IF endIdx < startIdx + 1 THEN
    throwCompilerError "EXPECTED NUMERIC ARGUMENT AFTER RANDOMIZE", ASIS, 0
    EXIT FUNCTION
  END IF

  tira_Start

  argVar$ = tiraParseExpressionInt$(startIdx + 1, endIdx, ALIM, "RANDOMIZE REQUIRES NUMERIC ARGUMENT")
  IF argVar$ = "" THEN
    tira_Cancel
    EXIT FUNCTION
  END IF

  tiraCall "IAT_SRAND", 1, argVar$

  tiraScheduleHeapReset
  tira_EndAndProcess

  parse_RANDOMIZE = 1

END FUNCTION ' parse_RANDOMIZE

''''''''''''''''''''''''
FUNCTION parse_READ (startIdx)

  DIM itemStart AS LONG
  DIM itemEnd AS LONG
  DIM commaIdx AS LONG
  DIM tokIdx AS LONG
  DIM closeParen AS LONG
  DIM vTok$, vName$
  DIM vIdx AS LONG
  DIM hasIndex AS LONG
  DIM hasField AS LONG
  DIM udtOffset AS LONG
  DIM fieldName$
  DIM uIdx AS LONG
  DIM fieldFound AS LONG
  DIM iField AS LONG
  DIM ptr$
  DIM targetType AS LONG
  DIM isStrVar AS LONG
  DIM endIdx AS LONG
  DIM indicesStr$
  DIM numParsedIndices AS LONG
  DIM currUdtIndex AS LONG
  DIM tempFieldSize AS LONG
  DIM tempIsDynamicString AS LONG
  DIM isFixedStr AS LONG
  DIM fixedLen AS LONG

  endIdx = lineTokenCount - 1

  IF endIdx < startIdx + 1 THEN
    throwCompilerError "READ MISSING VARIABLES", ASIS, 0
    EXIT FUNCTION
  END IF

  tira_Start

  itemStart = startIdx + 1
  DO WHILE itemStart <= endIdx
    itemEnd = endIdx
    commaIdx = findComma(itemStart, endIdx)
    IF commaIdx > 0 THEN itemEnd = commaIdx - 1

    tokIdx = itemStart
    vTok$ = lineTokens$(tokIdx)
    vName$ = UCASE$(vTok$)
    ff = resolveSymbol(vName$)
    IF ff = 0 THEN
      tira_Cancel
      EXIT FUNCTION
    END IF
    vIdx = returnedData2

    IF symbols(vIdx).IsExplicit = DECL_IMPLICIT THEN
      symbols(vIdx).IsExplicit = DECL_QUIET
    END IF

    targetType = symbols(vIdx).DataType

    tokIdx = tokIdx + 1

    hasIndex = 0
    indicesStr$ = ""
    numParsedIndices = 0

    IF tokIdx <= itemEnd THEN
      IF lineTokenVals(tokIdx) = 256 + ASC("(") THEN
        hasIndex = 1
        indicesStr$ = tiraParseArrayArgs$(tokIdx, itemEnd, 0)
        IF indicesStr$ = "" AND compileError = 1 THEN EXIT FUNCTION
        closeParen = returnedData2
        numParsedIndices = returnedData3
        tokIdx = closeParen + 1
      END IF
    END IF

    IF symbols(vIdx).NumDimensions > 0 AND numParsedIndices > 0 AND numParsedIndices <> symbols(vIdx).NumDimensions THEN
      throwCompilerError "WRONG NUMBER OF DIMENSIONS", ASIS, 0
      EXIT FUNCTION
    END IF

    hasField = 0
    udtOffset = 0
    currUdtIndex = symbols(vIdx).UDTIndex
    tempFieldSize = 0
    tempIsDynamicString = 0

    DO WHILE tokIdx <= itemEnd
      IF lineTokenVals(tokIdx) = 256 + ASC(".") THEN
        hasField = 1
        tokIdx = tokIdx + 1
        fieldName$ = UCASE$(lineTokens$(tokIdx))
        tokIdx = tokIdx + 1

        IF targetType <> TYPE_UDT THEN
          throwCompilerErrorAndCancelTira "VARIABLE IS NOT A UDT", ASIS, 0
          EXIT FUNCTION
        END IF

        fieldFound = 0
        FOR iField = 0 TO udts(currUdtIndex).FieldCount - 1
          IF RTRIM$(udtFields(currUdtIndex, iField).FieldName) = fieldName$ THEN
            udtOffset = udtOffset + udtFields(currUdtIndex, iField).Offset
            targetType = udtFields(currUdtIndex, iField).DataType
            tempFieldSize = udtFields(currUdtIndex, iField).Size
            tempIsDynamicString = udtFields(currUdtIndex, iField).IsDynamicString
            currUdtIndex = udtFields(currUdtIndex, iField).UDTIndex
            fieldFound = 1
            EXIT FOR
          END IF
        NEXT

        IF fieldFound = 0 THEN
          throwCompilerErrorAndCancelTira "UDT FIELD NOT FOUND", ASIS, 0
          EXIT FUNCTION
        END IF
      ELSE
        EXIT DO
      END IF
    LOOP

    ptr$ = tiraFrontendCalcAddress$(vName$, indicesStr$, udtOffset)
    IF ptr$ = "" THEN
      tira_Cancel
      EXIT FUNCTION
    END IF

    isStrVar = 0
    IF targetType = TYPE_STRING THEN isStrVar = 1

    isFixedStr = 0
    fixedLen = 0

    IF isStrVar = 1 THEN
      IF hasField = 1 THEN
        IF tempIsDynamicString = 0 THEN
          isFixedStr = 1
          fixedLen = tempFieldSize
        END IF
      ELSE
        fixedLen = retFixedStringLength(vIdx)
        IF fixedLen > 0 THEN
          isFixedStr = 1
        END IF
      END IF
    END IF

    IF isFixedStr = 1 THEN
      ' Read safely into a temporary dynamic string to respect raw character constraints
      tempDesc$ = tiraResolveHoistVar$("RDTMP", "_DESC$")
      tiraAssign tempDesc$, "!G_SYS_EMPTY_DESC$"

      tiraCall "RT_READ", 3, tempDesc$ + ", 1, " + cTrNum$(TYPE_STRING)

      ' Copy raw characters seamlessly into the fixed data buffer without memory corruption
      rhsDataPtr$ = tiraGetStringData$(tempDesc$)
      rhsLen$ = tiraGetStringLen$(tempDesc$)

      minLen$ = tiraDimVar$("T", TYPE_LONG)
      tiraAssign minLen$, rhsLen$
      tiraClamp minLen$, "", LTRIM$(STR$(fixedLen))

      tiraMemcpy ptr$, rhsDataPtr$, minLen$

      padLen$ = tiraDimVar$("T", TYPE_LONG)
      tiraOp TC_SUB, padLen$, LTRIM$(STR$(fixedLen)), minLen$
      skipPadLbl$ = tiraLabelCreateNew$("SKIP_PAD")
      tiraJmpCond "JLE", padLen$, "0", skipPadLbl$

      padAddr$ = tiraDimVar$("T", TYPE_INTEGER64)
      tiraOp TC_ADD, padAddr$, ptr$, minLen$
      tiraMemSet padAddr$, "32", padLen$
      tiraLabel skipPadLbl$

      ' Garbage collect the temporary dynamic string
      tiraCall "RT_STR_ASSIGN", 2, tempDesc$ + ", !G_SYS_EMPTY_DESC$"
    ELSE
      tiraCall "RT_READ", 3, ptr$ + ", " + cTrNum$(isStrVar) + ", " + cTrNum$(targetType)
    END IF

    itemStart = itemEnd + 2
  LOOP

  tiraScheduleHeapReset
  tira_EndAndProcess

  parse_READ = 1

END FUNCTION ' parse_READ

''''''''''''''''''''''''
FUNCTION parse_RED32$ (startIdx, endIdx, allowImplicit)

  DIM arg1$
  DIM scratchName$
  DIM resVar$
  DIM shiftVar$

  IF checkIntrinsicSyntax(startIdx, endIdx, "_RED32", 3) = 0 THEN
    parse_RED32$ = ""
    EXIT FUNCTION
  END IF

  tira_Start

  IF compileEmeraldMode = 1 THEN expectedSymType = TYPE_SINGLE

  arg1$ = tiraParseExpressionInt$(startIdx + 2, endIdx - 1, allowImplicit, "_RED32 ARG MUST BE NUMERIC")
  IF arg1$ = "" THEN
    tira_Cancel
    parse_RED32$ = ""
    EXIT FUNCTION
  END IF

  scratchName$ = tiraResolveHoistVar$("RED32", "_VAL")
  IF scratchName$ = "" THEN
    parse_RED32$ = ""
    EXIT FUNCTION
  END IF

  resVar$ = tiraDimVar$("T", TYPE_LONG)
  shiftVar$ = tiraDimVar$("T", TYPE_LONG)

  tiraOp TC_SHR, shiftVar$, arg1$, "16"
  tiraOp TC_AND, resVar$, shiftVar$, "255"

  tiraAssign scratchName$, resVar$

  tira_EndAndProcess

  exprIs.DataType = TYPE_LONG
  exprIs.IsTemp = 1
  parse_RED32$ = scratchName$

END FUNCTION ' parse_RED32$

''''''''''''''''''''''''
FUNCTION parse_RESTORE (startIdx)

  DIM endIdx AS LONG
  endIdx = lineTokenCount - 1

  tira_Start

  IF endIdx < startIdx + 1 THEN
    tiraAssign "!G_SYS_DATA_PTR_VAL", "0"
  ELSE
    lblTok$ = lineTokens$(startIdx + 1)
    lblName$ = "%" + UCASE$(lblTok$)
    expectedSymType = TYPE_LABEL
    ff = resolveSymbol(lblName$)
    IF ff = 1 THEN
      vIdx = returnedData2
      idxVal = symbols(vIdx).DataIndex
      tiraAssign "!G_SYS_DATA_PTR_VAL", LTRIM$(STR$(idxVal))
    ELSE
      tira_Cancel
      EXIT FUNCTION
    END IF
  END IF

  tiraScheduleHeapReset
  tira_EndAndProcess

  parse_RESTORE = 1

END FUNCTION ' parse_RESTORE

''''''''''''''''''''''''
FUNCTION parse_RESUME (startIdx)

  DIM endIdx AS LONG
  endIdx = lineTokenCount - 1

  tira_Start
  tiraScheduleHeapReset
  tiraNew TC_RESUME, ""
  tira_EndAndProcess

  parse_RESUME = 1

END FUNCTION ' parse_RESUME

''''''''''''''''''''''''
FUNCTION parse_RGB$ (startIdx, endIdx, allowImplicit)

  DIM argR$
  DIM argG$
  DIM argB$
  DIM comma1 AS LONG
  DIM comma2 AS LONG
  DIM scratchName$
  DIM maskR$
  DIM maskG$
  DIM maskB$
  DIM idx$
  DIM bestIdx$
  DIM minDist$
  DIM palDescPtr$
  DIM palDataAddr$
  DIM loopTop$
  DIM loopDone$
  DIM offsetVar$
  DIM targetAddr$
  DIM palB$
  DIM palG_addr$
  DIM palG$
  DIM palR_addr$
  DIM palR$
  DIM diffR$
  DIM diffG$
  DIM diffB$
  DIM sqR$
  DIM sqG$
  DIM sqB$
  DIM dist$
  DIM skipUpdate$

  IF checkIntrinsicSyntax(startIdx, endIdx, "_RGB", 7) = 0 THEN
    parse_RGB$ = ""
    EXIT FUNCTION
  END IF

  comma1 = findComma(startIdx + 2, endIdx - 1)
  IF comma1 = 0 THEN
    throwCompilerError "_RGB REQUIRES 3 ARGUMENTS", ASIS, 0
    parse_RGB$ = ""
    EXIT FUNCTION
  END IF

  comma2 = findComma(comma1 + 1, endIdx - 1)
  IF comma2 = 0 THEN
    throwCompilerError "_RGB REQUIRES 3 ARGUMENTS", ASIS, 0
    parse_RGB$ = ""
    EXIT FUNCTION
  END IF

  tira_Start

  IF compileEmeraldMode = 1 THEN expectedSymType = TYPE_SINGLE

  argR$ = tiraParseExpressionInt$(startIdx + 2, comma1 - 1, allowImplicit, "_RGB RED ARG MUST BE NUMERIC")
  IF argR$ = "" THEN
    parse_RGB$ = ""
    EXIT FUNCTION
  END IF

  argG$ = tiraParseExpressionInt$(comma1 + 1, comma2 - 1, allowImplicit, "_RGB GREEN ARG MUST BE NUMERIC")
  IF argG$ = "" THEN
    parse_RGB$ = ""
    EXIT FUNCTION
  END IF

  argB$ = tiraParseExpressionInt$(comma2 + 1, endIdx - 1, allowImplicit, "_RGB BLUE ARG MUST BE NUMERIC")
  IF argB$ = "" THEN
    parse_RGB$ = ""
    EXIT FUNCTION
  END IF

  scratchName$ = tiraResolveHoistVar$("RGB", "_VAL")
  IF scratchName$ = "" THEN
    parse_RGB$ = ""
    EXIT FUNCTION
  END IF

  ' Force incoming values to 0-255 limits cleanly before calculation
  maskR$ = tiraDimVar$("T", TYPE_LONG)
  tiraOp TC_AND, maskR$, argR$, "255"

  maskG$ = tiraDimVar$("T", TYPE_LONG)
  tiraOp TC_AND, maskG$, argG$, "255"

  maskB$ = tiraDimVar$("T", TYPE_LONG)
  tiraOp TC_AND, maskB$, argB$, "255"

  idx$ = tiraDimVar$("T", TYPE_LONG)
  tiraAssign idx$, "0"

  bestIdx$ = tiraDimVar$("T", TYPE_LONG)
  tiraAssign bestIdx$, "0"

  minDist$ = tiraDimVar$("T", TYPE_LONG)
  tiraAssign minDist$, "9999999"

  ' Read directly from the internal compiler global palette block memory
  palDescPtr$ = tiraDimVar$("T", TYPE_INTEGER64)
  tiraAssign palDescPtr$, "!G_GFX_PALETTE_DESC$"

  palDataAddr$ = tiraDimVar$("T", TYPE_INTEGER64)
  tiraNew TC_READ_MEM, palDataAddr$ + ", " + palDescPtr$

  loopTop$ = tiraLabelCreateNew$("RGB_LOOP")
  loopDone$ = tiraLabelCreateNew$("RGB_DONE")

  tiraLabel loopTop$
  tiraJmpCond "JG", idx$, "255", loopDone$

  offsetVar$ = tiraDimVar$("T", TYPE_INTEGER64)
  tiraOp TC_MUL, offsetVar$, idx$, "4"

  targetAddr$ = tiraDimVar$("T", TYPE_INTEGER64)
  tiraOp TC_ADD, targetAddr$, palDataAddr$, offsetVar$

  palB$ = tiraDimVar$("T", TYPE_UBYTE)
  tiraNew TC_READ_MEM, palB$ + ", " + targetAddr$

  palG_addr$ = tiraDimVar$("T", TYPE_INTEGER64)
  tiraOp TC_ADD, palG_addr$, targetAddr$, "1"
  palG$ = tiraDimVar$("T", TYPE_UBYTE)
  tiraNew TC_READ_MEM, palG$ + ", " + palG_addr$

  palR_addr$ = tiraDimVar$("T", TYPE_INTEGER64)
  tiraOp TC_ADD, palR_addr$, targetAddr$, "2"
  palR$ = tiraDimVar$("T", TYPE_UBYTE)
  tiraNew TC_READ_MEM, palR$ + ", " + palR_addr$

  ' Calculate the numerical difference between the target pixel and the current index pixel
  diffR$ = tiraDimVar$("T", TYPE_LONG)
  tiraOp TC_SUB, diffR$, maskR$, palR$

  diffG$ = tiraDimVar$("T", TYPE_LONG)
  tiraOp TC_SUB, diffG$, maskG$, palG$

  diffB$ = tiraDimVar$("T", TYPE_LONG)
  tiraOp TC_SUB, diffB$, maskB$, palB$

  ' Square the differences internally to isolate purely positive vector distances
  sqR$ = tiraDimVar$("T", TYPE_LONG)
  tiraOp TC_MUL, sqR$, diffR$, diffR$

  sqG$ = tiraDimVar$("T", TYPE_LONG)
  tiraOp TC_MUL, sqG$, diffG$, diffG$

  sqB$ = tiraDimVar$("T", TYPE_LONG)
  tiraOp TC_MUL, sqB$, diffB$, diffB$

  dist$ = tiraDimVar$("T", TYPE_LONG)
  tiraOp TC_ADD, dist$, sqR$, sqG$
  tiraOp TC_ADD, dist$, dist$, sqB$

  ' Skip overriding the best match if this index is farther away than our currently held match
  skipUpdate$ = tiraLabelCreateNew$("RGB_SKIP_UPD")
  tiraJmpCond "JGE", dist$, minDist$, skipUpdate$
  tiraAssign minDist$, dist$
  tiraAssign bestIdx$, idx$

  ' Speed optimization: If exact perfect distance hit 0 is reached, terminate scan early
  tiraJmpCond "JE", dist$, "0", loopDone$
  tiraLabel skipUpdate$

  tiraOp TC_ADD, idx$, idx$, "1"
  tiraJmp loopTop$

  tiraLabel loopDone$

  tiraAssign scratchName$, bestIdx$

  tira_EndAndProcess

  exprIs.DataType = TYPE_LONG
  exprIs.IsTemp = 1
  parse_RGB$ = scratchName$

END FUNCTION ' parse_RGB$

''''''''''''''''''''''''
FUNCTION parse_RGB32$ (startIdx, endIdx, allowImplicit)

  DIM argR$
  DIM argG$
  DIM argB$
  DIM comma1 AS LONG
  DIM comma2 AS LONG
  DIM scratchName$
  DIM maskR$
  DIM maskG$
  DIM maskB$
  DIM shiftG$
  DIM shiftR$
  DIM alphaVal$
  DIM resVar$

  IF checkIntrinsicSyntax(startIdx, endIdx, "_RGB32", 7) = 0 THEN
    parse_RGB32$ = ""
    EXIT FUNCTION
  END IF

  comma1 = findComma(startIdx + 2, endIdx - 1)
  IF comma1 = 0 THEN
    throwCompilerError "_RGB32 REQUIRES 3 ARGUMENTS", ASIS, 0
    parse_RGB32$ = ""
    EXIT FUNCTION
  END IF

  comma2 = findComma(comma1 + 1, endIdx - 1)
  IF comma2 = 0 THEN
    throwCompilerError "_RGB32 REQUIRES 3 ARGUMENTS", ASIS, 0
    parse_RGB32$ = ""
    EXIT FUNCTION
  END IF

  tira_Start

  IF compileEmeraldMode = 1 THEN expectedSymType = TYPE_SINGLE

  argR$ = tiraParseExpressionInt$(startIdx + 2, comma1 - 1, allowImplicit, "_RGB32 RED ARG MUST BE NUMERIC")
  IF argR$ = "" THEN
    parse_RGB32$ = ""
    EXIT FUNCTION
  END IF

  argG$ = tiraParseExpressionInt$(comma1 + 1, comma2 - 1, allowImplicit, "_RGB32 GREEN ARG MUST BE NUMERIC")
  IF argG$ = "" THEN
    parse_RGB32$ = ""
    EXIT FUNCTION
  END IF

  argB$ = tiraParseExpressionInt$(comma2 + 1, endIdx - 1, allowImplicit, "_RGB32 BLUE ARG MUST BE NUMERIC")
  IF argB$ = "" THEN
    parse_RGB32$ = ""
    EXIT FUNCTION
  END IF

  scratchName$ = tiraResolveHoistVar$("RGB32", "_VAL")
  IF scratchName$ = "" THEN
    parse_RGB32$ = ""
    EXIT FUNCTION
  END IF

  maskR$ = tiraDimVar$("T", TYPE_LONG)
  tiraOp TC_AND, maskR$, argR$, "255"

  maskG$ = tiraDimVar$("T", TYPE_LONG)
  tiraOp TC_AND, maskG$, argG$, "255"

  maskB$ = tiraDimVar$("T", TYPE_LONG)
  tiraOp TC_AND, maskB$, argB$, "255"

  shiftG$ = tiraDimVar$("T", TYPE_LONG)
  tiraOp TC_SHL, shiftG$, maskG$, "8"

  shiftR$ = tiraDimVar$("T", TYPE_LONG)
  tiraOp TC_SHL, shiftR$, maskR$, "16"

  ' Default the missing alpha value safely to &HFF000000 (-16777216)
  alphaVal$ = tiraDimVar$("T", TYPE_LONG)
  tiraAssign alphaVal$, "-16777216"

  resVar$ = tiraDimVar$("T", TYPE_LONG)
  tiraOp TC_ADD, resVar$, maskB$, shiftG$
  tiraOp TC_ADD, resVar$, resVar$, shiftR$
  tiraOp TC_ADD, resVar$, resVar$, alphaVal$

  tiraAssign scratchName$, resVar$

  tira_EndAndProcess

  exprIs.DataType = TYPE_LONG
  exprIs.IsTemp = 1
  parse_RGB32$ = scratchName$

END FUNCTION ' parse_RGB32$

''''''''''''''''''''''''
FUNCTION parse_SCREENICON (startIdx)

  DIM endIdx AS LONG

  endIdx = lineTokenCount - 1

  IF compileHasGraphics = 0 THEN
    throwCompilerError "_SCREENICON REQUIRES #GRAPHICS", ASIS, 0
    EXIT FUNCTION
  END IF

  tira_Start

  ' Parse the optional handle argument if provided to ensure syntax checking
  IF endIdx > startIdx THEN
    argVar$ = tiraParseExpressionInt$(startIdx + 1, endIdx, ALIM, "ICON HANDLE MUST BE NUMERIC")
    IF argVar$ = "" THEN
      tira_Cancel
      EXIT FUNCTION
    END IF
  END IF

  tiraScheduleHeapReset
  tira_EndAndProcess

  parse_SCREENICON = 1

END FUNCTION ' parse_SCREENICON

''''''''''''''''''''''''
FUNCTION parse_SGN$ (startIdx, endIdx, allowImplicit)

  DIM arg1$
  DIM scratchName$
  DIM resVar$
  DIM lblPos$
  DIM lblEnd$

  IF checkIntrinsicSyntax(startIdx, endIdx, "SGN", 3) = 0 THEN
    parse_SGN$ = ""
    EXIT FUNCTION
  END IF

  tira_Start

  IF compileEmeraldMode = 1 THEN expectedSymType = TYPE_SINGLE

  arg1$ = tiraParseExpressionNumeric$(startIdx + 2, endIdx - 1, allowImplicit, "INTRINSIC REQUIRES NUMERIC")
  IF arg1$ = "" THEN
    parse_SGN$ = ""
    EXIT FUNCTION
  END IF

  scratchName$ = tiraResolveHoistVar$("SGN", "_VAL")
  IF scratchName$ = "" THEN
    parse_SGN$ = ""
    EXIT FUNCTION
  END IF

  resVar$ = tiraDimVar$("T", TYPE_LONG)
  tiraAssign resVar$, "0"

  lblPos$ = tiraLabelCreateNew$("SGN_POS")
  lblEnd$ = tiraLabelCreateNew$("SGN_END")

  ' TC_JMP_COND seamlessly handles float/integer mixed conditions safely using UCOMI
  tiraJmpCond "JE", arg1$, "0", lblEnd$
  tiraJmpCond "JG", arg1$, "0", lblPos$

  tiraAssign resVar$, "-1"
  tiraJmp lblEnd$

  tiraLabel lblPos$
  tiraAssign resVar$, "1"

  tiraLabel lblEnd$
  tiraAssign scratchName$, resVar$

  tira_EndAndProcess

  exprIs.DataType = TYPE_LONG
  exprIs.IsTemp = 1
  parse_SGN$ = scratchName$

END FUNCTION ' parse_SGN$

''''''''''''''''''''''''
FUNCTION parse_SHELL (startIdx)

  DIM endIdx AS LONG
  DIM hasHide AS LONG
  DIM cmdStart AS LONG
  DIM cmdStr$
  DIM strDataPtr$
  DIM hideVal$
  DIM tokVal AS LONG

  endIdx = lineTokenCount - 1
  hasHide = 0
  cmdStart = startIdx + 1

  DO WHILE cmdStart <= endIdx
    tokVal = lineTokenVals(cmdStart)

    SELECT CASE tokVal

      CASE TOK_HIDE
        hasHide = 1
        cmdStart = cmdStart + 1
      CASE TOK_DONTWAIT
        ' WinExec is asynchronous by default in our implementation, so we just consume the token
        cmdStart = cmdStart + 1
      CASE ELSE
        EXIT DO

    END SELECT ' tokVak

  LOOP

  IF cmdStart > endIdx THEN
    throwCompilerError "EXPECTED COMMAND STRING", ASIS, 0
    EXIT FUNCTION
  END IF

  tira_Start

  IF compileEmeraldMode = 1 THEN expectedSymType = TYPE_STRING

  cmdStr$ = tiraParseExpression$(cmdStart, endIdx, ALIM)
  IF cmdStr$ = "" THEN
    tira_Cancel
    EXIT FUNCTION
  END IF

  IF exprIs.DataType <> TYPE_STRING THEN
    throwCompilerErrorAndCancelTira "COMMAND MUST BE A STRING", ASIS, 0
    EXIT FUNCTION
  END IF

  ' Extract raw pointer to our seamlessly null-terminated C string in memory
  strDataPtr$ = tiraGetStringData$(cmdStr$)

  hideVal$ = tiraDimVar$("T", TYPE_LONG)
  IF hasHide = 1 THEN
    tiraAssign hideVal$, "0" ' SW_HIDE flag
  ELSE
    tiraAssign hideVal$, "1" ' SW_SHOWNORMAL flag
  END IF

  ' Call Windows API to spawn the subprocess cleanly
  tiraCall "IAT_WINEXEC", 2, strDataPtr$ + ", " + hideVal$

  tiraScheduleHeapReset
  tira_EndAndProcess

  parse_SHELL = 1

END FUNCTION ' parse_SHELL

''''''''''''''''''''''''
FUNCTION parse_SIN$ (startIdx, endIdx, allowImplicit)

  DIM arg1$
  DIM scratchName$
  DIM resVar$
  DIM singleRes$
  DIM argFloat$

  IF checkIntrinsicSyntax(startIdx, endIdx, "SIN", 3) = 0 THEN
    parse_SIN$ = ""
    EXIT FUNCTION
  END IF

  tira_Start

  IF compileEmeraldMode = 1 THEN expectedSymType = TYPE_SINGLE

  arg1$ = tiraParseExpressionNumeric$(startIdx + 2, endIdx - 1, allowImplicit, "INTRINSIC REQUIRES NUMERIC")
  IF arg1$ = "" THEN
    parse_SIN$ = ""
    EXIT FUNCTION
  END IF

  scratchName$ = tiraResolveHoistVar$("SIN", "_VAL")
  IF scratchName$ = "" THEN
    parse_SIN$ = ""
    EXIT FUNCTION
  END IF

  ' Explicitly override the integer prefix rule to safely route as float
  ff = resolveSymbol(scratchName$)
  IF ff = 1 THEN symbols(returnedData2).DataType = TYPE_SINGLE

  resVar$ = tiraDimVar$("T", TYPE_DOUBLE)

  ' Coerce the argument to a double for the external IAT function
  IF exprIs.DataType <> TYPE_DOUBLE THEN
    argFloat$ = tiraDimVar$("T", TYPE_DOUBLE)
    tiraAssign argFloat$, arg1$
    arg1$ = argFloat$
  END IF

  tiraCall "IAT_SIN", 1, arg1$
  tiraNew TC_GET_RET, resVar$

  singleRes$ = tiraDimVar$("T", TYPE_SINGLE)
  tiraOp TC_CAST, singleRes$, resVar$, LTRIM$(STR$(TYPE_SINGLE))

  tiraAssign scratchName$, singleRes$

  tira_EndAndProcess

  exprIs.DataType = TYPE_SINGLE
  exprIs.IsTemp = 1
  parse_SIN$ = scratchName$

END FUNCTION ' parse_SIN$

''''''''''''''''''''''''
FUNCTION parse_SPACE$ (startIdx, endIdx, allowImplicit)

  DIM arg1$
  DIM scratchName$
  DIM skipLen$
  DIM dataPtr$
  DIM descPtr$
  DIM jmpDone$

  IF checkIntrinsicSyntax(startIdx, endIdx, "SPACE$", 3) = 0 THEN
    parse_SPACE$ = ""
    EXIT FUNCTION
  END IF

  ' Sovereign command opens its own compilation block
  tira_Start

  IF compileEmeraldMode = 1 THEN expectedSymType = TYPE_SINGLE
  arg1$ = tiraParseExpressionInt$(startIdx + 2, endIdx - 1, allowImplicit, "SPACE$ REQUIRES NUMERIC ARGUMENT")
  IF arg1$ = "" THEN
    parse_SPACE$ = ""
    EXIT FUNCTION
  END IF

  scratchName$ = tiraResolveHoistVar$("SPACE", "_DESC$")
  IF scratchName$ = "" THEN
    parse_SPACE$ = ""
    EXIT FUNCTION
  END IF

  descPtr$ = tiraDimVar$("T", TYPE_INTEGER64)
  tiraAssign descPtr$, scratchName$

  skipLen$ = tiraLabelCreateNew$("SPACE_SKIP")

  tiraJmpCond "JLE", arg1$, "0", skipLen$

  dataPtr$ = tiraAllocTempMem$(arg1$)

  ' Memset with 32 (space character)
  tiraMemSet dataPtr$, "32", arg1$

  tiraBuildStringDescriptor descPtr$, dataPtr$, arg1$, "0"

  jmpDone$ = tiraLabelCreateNew$("SPACE_DONE")
  tiraJmp jmpDone$

  tiraLabel skipLen$
  ' Safely construct an empty descriptor entirely within the Temp Heap paradigm
  tiraBuildStringDescriptor descPtr$, "0", "0", "0"
  tiraLabel jmpDone$

  ' Close the block (NO HEAP RESET, so the string survives for the parent!)
  tira_EndAndProcess

  exprIs.DataType = TYPE_STRING
  exprIs.IsTemp = 1
  parse_SPACE$ = scratchName$

END FUNCTION ' parse_SPACE$

''''''''''''''''''''''''
FUNCTION parse_STRINGFUNC$ (startIdx, endIdx, allowImplicit)

  DIM comma1 AS LONG
  DIM arg1$
  DIM arg2$
  DIM scratchName$
  DIM descPtr$
  DIM dataPtr$
  DIM charByte$
  DIM isStringChar AS LONG
  DIM strLen$
  DIM strData$
  DIM lblEmpty$
  DIM lblNotEmpty$
  DIM lblValidCount$
  DIM lblDoAlloc$
  DIM lblDone$
  DIM errStr$
  DIM tmpByte$

  IF checkIntrinsicSyntax(startIdx, endIdx, "STRING$", 5) = 0 THEN
    parse_STRINGFUNC$ = ""
    EXIT FUNCTION
  END IF

  comma1 = findComma(startIdx + 2, endIdx - 1)
  IF comma1 = 0 THEN
    throwCompilerError "STRING$ REQUIRES TWO ARGUMENTS", ASIS, 0
    parse_STRINGFUNC$ = ""
    EXIT FUNCTION
  END IF

  tira_Start

  IF compileEmeraldMode = 1 THEN expectedSymType = TYPE_SINGLE
  arg1$ = tiraParseExpressionInt$(startIdx + 2, comma1 - 1, allowImplicit, "STRING$ ARG 1 MUST BE NUMERIC")
  IF arg1$ = "" THEN
    tira_Cancel
    parse_STRINGFUNC$ = ""
    EXIT FUNCTION
  END IF

  expectedSymType = TYPE_ANY
  arg2$ = tiraParseExpression$(comma1 + 1, endIdx - 1, allowImplicit)
  IF arg2$ = "" THEN
    tira_Cancel
    parse_STRINGFUNC$ = ""
    EXIT FUNCTION
  END IF

  isStringChar = 0
  IF exprIs.DataType = TYPE_STRING THEN isStringChar = 1

  scratchName$ = tiraResolveHoistVar$("STRF", "_DESC$")
  IF scratchName$ = "" THEN
    parse_STRINGFUNC$ = ""
    EXIT FUNCTION
  END IF

  lblValidCount$ = tiraLabelCreateNew$("STRF_VCNT")
  tiraJmpCond "JGE", arg1$, "0", lblValidCount$

  errStr$ = CHR$(34) + "PROGRAM TERMINATED: ILLEGAL FUNCTION CALL IN STRING$ ON LINE " + retLineNumberStr$ + CHR$(34)
  tiraCall "RT_PRINT_STR", 1, errStr$
  tiraCall "RT_CRLF", 0, ""
  tiraJmp "@END_PROGRAM"

  tiraLabel lblValidCount$

  charByte$ = tiraDimVar$("T", TYPE_LONG)

  IF isStringChar = 1 THEN
    strLen$ = tiraGetStringLen$(arg2$)

    lblEmpty$ = tiraLabelCreateNew$("STRF_MT")
    lblNotEmpty$ = tiraLabelCreateNew$("STRF_NMT")

    tiraJmpCond "JLE", strLen$, "0", lblEmpty$

    strData$ = tiraGetStringData$(arg2$)
    tmpByte$ = tiraDimVar$("T", TYPE_UBYTE)
    tiraNew TC_READ_MEM, tmpByte$ + ", " + strData$
    tiraAssign charByte$, tmpByte$
    tiraJmp lblNotEmpty$

    tiraLabel lblEmpty$
    errStr$ = CHR$(34) + "PROGRAM TERMINATED: ILLEGAL FUNCTION CALL IN STRING$ ON LINE " + retLineNumberStr$ + CHR$(34)
    tiraCall "RT_PRINT_STR", 1, errStr$
    tiraCall "RT_CRLF", 0, ""
    tiraJmp "@END_PROGRAM"

    tiraLabel lblNotEmpty$
  ELSE
    tiraOp TC_AND, charByte$, arg2$, "255"
  END IF

  lblDoAlloc$ = tiraLabelCreateNew$("STRF_ALLOC")
  lblDone$ = tiraLabelCreateNew$("STRF_DONE")

  descPtr$ = tiraDimVar$("T", TYPE_INTEGER64)
  tiraAssign descPtr$, scratchName$

  tiraJmpCond "JG", arg1$, "0", lblDoAlloc$

  tiraBuildStringDescriptor descPtr$, "0", "0", "0"
  tiraJmp lblDone$

  tiraLabel lblDoAlloc$
  dataPtr$ = tiraAllocTempMem$(arg1$)

  tiraMemSet dataPtr$, charByte$, arg1$

  tiraBuildStringDescriptor descPtr$, dataPtr$, arg1$, "0"

  tiraLabel lblDone$

  tira_EndAndProcess

  exprIs.DataType = TYPE_STRING
  exprIs.IsTemp = 1
  parse_STRINGFUNC$ = scratchName$

END FUNCTION ' parse_STRINGFUNC$

''''''''''''''''''''''''
FUNCTION parse_TIMER$ (startIdx, endIdx, allowImplicit)

  DIM scratchName$
  DIM tickVal$
  DIM tickDouble$
  DIM resVar$
  DIM singleRes$

  IF startIdx <> endIdx THEN
    throwCompilerError "MALFORMED TIMER", ASIS, 0
    parse_TIMER$ = ""
    EXIT FUNCTION
  END IF

  tira_Start

  scratchName$ = tiraResolveHoistVar$("TIMER", "_VAL")
  IF scratchName$ = "" THEN
    parse_TIMER$ = ""
    EXIT FUNCTION
  END IF

  ' Explicitly override the integer prefix rule to safely route as float
  ff = resolveSymbol(scratchName$)
  IF ff = 1 THEN symbols(returnedData2).DataType = TYPE_SINGLE

  tiraCall "IAT_GETTICKCOUNT", 0, ""

  tickVal$ = tiraDimVar$("T", TYPE_LONG)
  tiraNew TC_GET_RET, tickVal$

  tickDouble$ = tiraDimVar$("T", TYPE_DOUBLE)
  tiraOp TC_CAST, tickDouble$, tickVal$, LTRIM$(STR$(TYPE_DOUBLE))

  resVar$ = tiraDimVar$("T", TYPE_DOUBLE)
  tiraOp TC_DIV, resVar$, tickDouble$, "1000.0#"

  singleRes$ = tiraDimVar$("T", TYPE_SINGLE)
  tiraOp TC_CAST, singleRes$, resVar$, LTRIM$(STR$(TYPE_SINGLE))

  tiraAssign scratchName$, singleRes$

  tira_EndAndProcess

  exprIs.DataType = TYPE_SINGLE
  exprIs.IsTemp = 1
  parse_TIMER$ = scratchName$

END FUNCTION ' parse_TIMER$

''''''''''''''''''''''''
FUNCTION parse_UBOUND$ (startIdx, endIdx, allowImplicit)

  DIM arrNameTok$
  DIM comma1 AS LONG
  DIM vIdx AS LONG
  DIM scratchName$
  DIM dimVar$
  DIM resVar$
  DIM lblEnd$

  IF checkIntrinsicSyntax(startIdx, endIdx, "UBOUND", 3) = 0 THEN
    parse_UBOUND$ = ""
    EXIT FUNCTION
  END IF

  comma1 = findComma(startIdx + 2, endIdx - 1)

  arrNameTok$ = UCASE$(retTokenText$(lineTokens$(startIdx + 2)))
  ff = resolveSymbol(arrNameTok$)
  IF ff = 0 THEN
    parse_UBOUND$ = ""
    EXIT FUNCTION
  END IF
  vIdx = returnedData2

  IF symbols(vIdx).IsArray = 0 THEN
    throwCompilerError "UBOUND REQUIRES AN ARRAY", ASIS, 0
    parse_UBOUND$ = ""
    EXIT FUNCTION
  END IF

  tira_Start

  IF comma1 > 0 THEN
    dimVar$ = tiraParseExpressionInt$(comma1 + 1, endIdx - 1, allowImplicit, "DIMENSION MUST BE NUMERIC")
    IF dimVar$ = "" THEN
      parse_UBOUND$ = ""
      EXIT FUNCTION
    END IF
  ELSE
    dimVar$ = "1"
  END IF

  scratchName$ = tiraResolveHoistVar$("UBOUND", "_VAL")
  IF scratchName$ = "" THEN
    parse_UBOUND$ = ""
    EXIT FUNCTION
  END IF

  resVar$ = tiraDimVar$("T", TYPE_LONG)

  descAddr$ = tiraDimVar$("T", TYPE_INTEGER64)
  tiraOp TC_ADDRESS_OF, descAddr$, "#" + LTRIM$(STR$(vIdx)), ""

  numDims$ = tiraDimVar$("T", TYPE_LONG)
  tiraNew TC_READ_MEM_OFFSET, numDims$ + ", " + descAddr$ + ", 12"

  lblEnd$ = tiraLabelCreateNew$("UB_END")
  tiraAssign resVar$, "0"
  tiraJmpCond "JG", dimVar$, numDims$, lblEnd$
  tiraJmpCond "JL", dimVar$, "1", lblEnd$

  offsetVar$ = tiraDimVar$("T", TYPE_LONG)
  tiraOp TC_SUB, offsetVar$, dimVar$, "1"
  tiraOp TC_MUL, offsetVar$, offsetVar$, "8"
  tiraOp TC_ADD, offsetVar$, offsetVar$, "16"

  dimLimitAddr$ = tiraDimVar$("T", TYPE_INTEGER64)
  tiraOp TC_ADD, dimLimitAddr$, descAddr$, offsetVar$

  axVar$ = tiraDimVar$("T", TYPE_INTEGER64)
  tiraNew TC_READ_MEM, axVar$ + ", " + dimLimitAddr$

  tiraOp TC_SUB, resVar$, axVar$, "1"

  tiraLabel lblEnd$
  tiraAssign scratchName$, resVar$

  tira_EndAndProcess

  exprIs.DataType = TYPE_LONG
  exprIs.IsTemp = 1
  parse_UBOUND$ = scratchName$

END FUNCTION ' parse_UBOUND$
