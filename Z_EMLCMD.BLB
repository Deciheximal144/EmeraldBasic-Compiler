''''''''''''''''''''''''
FUNCTION parse_MOUSEBUTTON$ (startIdx, endIdx, allowImplicit)

  DIM arg1$
  DIM scratchName$
  DIM resVar$
  DIM lblB2$
  DIM lblB3$
  DIM lblEnd$

  IF checkIntrinsicSyntax(startIdx, endIdx, "_MOUSEBUTTON", 3) = 0 THEN
    parse_MOUSEBUTTON$ = ""
    EXIT FUNCTION
  END IF

  IF compileHasGraphics = 0 THEN
    throwCompilerError "_MOUSEBUTTON REQUIRES #GRAPHICS", ASIS, 0
    parse_MOUSEBUTTON$ = ""
    EXIT FUNCTION
  END IF

  tira_Start

  IF compileEmeraldMode = 1 THEN expectedSymType = TYPE_SINGLE

  arg1$ = tiraParseExpressionInt$(startIdx + 2, endIdx - 1, allowImplicit, "INTRINSIC REQUIRES NUMERIC")
  IF arg1$ = "" THEN
    parse_MOUSEBUTTON$ = ""
    EXIT FUNCTION
  END IF

  scratchName$ = tiraResolveHoistVar$("MOUSEBUTTON", "_VAL")
  IF scratchName$ = "" THEN
    parse_MOUSEBUTTON$ = ""
    EXIT FUNCTION
  END IF

  resVar$ = tiraDimVar$("T", TYPE_LONG)

  lblB2$ = tiraLabelCreateNew$("MB_2")
  lblB3$ = tiraLabelCreateNew$("MB_3")
  lblEnd$ = tiraLabelCreateNew$("MB_END")

  tiraJmpCond "JE", arg1$, "2", lblB2$
  tiraJmpCond "JE", arg1$, "3", lblB3$
  tiraAssign resVar$, "!G_IO_MOUSE_B1_VAL"
  tiraJmp lblEnd$

  tiraLabel lblB2$
  tiraAssign resVar$, "!G_IO_MOUSE_B2_VAL"
  tiraJmp lblEnd$

  tiraLabel lblB3$
  tiraAssign resVar$, "!G_IO_MOUSE_B3_VAL"

  tiraLabel lblEnd$
  tiraAssign scratchName$, resVar$

  tira_EndAndProcess

  exprIs.DataType = TYPE_LONG
  exprIs.IsTemp = 1
  parse_MOUSEBUTTON$ = scratchName$

END FUNCTION ' parse_MOUSEBUTTON$

''''''''''''''''''''''''
FUNCTION parse_MOUSEINPUT$ (startIdx, endIdx, allowImplicit)

  DIM scratchName$
  DIM resVar$

  IF startIdx <> endIdx THEN
    throwCompilerError "MALFORMED _MOUSEINPUT", ASIS, 0
    parse_MOUSEINPUT$ = ""
    EXIT FUNCTION
  END IF

  IF compileHasGraphics = 0 THEN
    throwCompilerError "_MOUSEINPUT REQUIRES #GRAPHICS", ASIS, 0
    parse_MOUSEINPUT$ = ""
    EXIT FUNCTION
  END IF

  tira_Start

  scratchName$ = tiraResolveHoistVar$("MOUSEINPUT", "_VAL")
  IF scratchName$ = "" THEN
    parse_MOUSEINPUT$ = ""
    EXIT FUNCTION
  END IF

  tiraCall "RT_MOUSEINPUT", 0, ""

  resVar$ = tiraDimVar$("T", TYPE_LONG)
  tiraNew TC_GET_RET, resVar$

  tiraAssign scratchName$, resVar$

  tira_EndAndProcess

  exprIs.DataType = TYPE_LONG
  exprIs.IsTemp = 1
  parse_MOUSEINPUT$ = scratchName$

END FUNCTION ' parse_MOUSEINPUT$

